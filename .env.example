# FitGenie - Environment Variables
#    ⚠️  IMPORTANTE:
#    Estos valores son para DESARROLLO LOCAL únicamente
#    Estos son ejemplos, CAMBIAR EN CASO DE USAR EN PRODUCCIÓN


# Database
DATABASE_URL=postgres://fitgenie:fitgenie123@localhost:5432/fitgenie?sslmode=disable

# Server
PORT=8080
GIN_MODE=debug

# JWT (cambiar en producción)
JWT_SECRET=change-me-in-production-to-a-256-bit-secret-key

# S3 / LocalStack (desarrollo)
S3_ENDPOINT=http://localhost:4566
S3_REGION=us-east-1
S3_BUCKET=fitgenie-images
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_USE_PATH_STYLE=true

# Features
COLOR_ANALYSIS_ENABLED=true
STYLE_ANALYSIS_ENABLED=true
MAX_IMAGE_SIZE=5242880
